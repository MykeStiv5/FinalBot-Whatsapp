{
  "name": "bot-whatsapp-clean",
  "version": "1.0.0",
  "description": "Bot WhatsApp RSS Electron",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently \"node src/server.js\" \"electron .\"",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.bot.whatsapp",
    "productName": "Bot WhatsApp",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "ui/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "portable"
    }
  },
  "dependencies": {
    "axios": "^1.16.1",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "puppeteer": "^25.0.4",
    "qrcode": "^1.5.4",
    "rss": "^1.2.2",
    "rss-parser": "^3.13.0",
    "whatsapp-web.js": "^1.23.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  }
}
